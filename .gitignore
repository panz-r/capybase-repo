# build / dist
build/
dist/
*.egg-info/

# compiled C extensions (platform-specific; rebuilt from .c via setup.py)
*.so

# python
__pycache__/
*.py[cod]
*$py.class

# test / tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# test logs from scripts/run-live-test.sh
logs/

# capybase runtime artifacts (journals, prompts, candidates, snapshots)
.rebase-agent/

# local config overrides
capybase.local.toml

# venvs
.venv/
venv/

# real-world merge-conflict dataset artifacts (Method D). Each directory below
# keeps a committed .gitignore (ignore-everything) so the EMPTY directory is
# tracked and exists on a fresh clone; contents are regenerated by
# scripts/fetch_mergeconflict_datasets.py and read by tests/realworld_loader.py.
# Tests skip cleanly when these are empty (data not downloaded).
# (Contents are ignored by each dir's own .gitignore; listed here for visibility.)
uv.lock

# ZCode session artifacts
.zcode/
